# Local development (copy to .env)
OPENAI_API_KEY=sk-your-key-here
DEBUG=True
SECRET_KEY=dev-only-change-in-production
# For fastest local dev, omit DATABASE_URL to use SQLite.
# Only set DATABASE_URL when you need to test against Railway Postgres.

# Railway production — set these on the web service (not in git)
# DEBUG=False
# SECRET_KEY=generate-a-long-random-string
# ALLOWED_HOSTS=your-app.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
# DATABASE_URL is injected automatically when you add a PostgreSQL plugin.
# DATABASE_SSL=true  # default in production; Railway Postgres expects SSL
# Place the web service and Postgres plugin in the same Railway region for lower latency.
# RAILWAY_PUBLIC_DOMAIN is set automatically for the web service public URL.
# ALLOW_PUBLIC_REGISTRATION=false  # disable /register/ on production if needed

# Gmail / email alerts when someone posts an EOD (boss + manager)
# NOTIFY_EMAIL_ENABLED=true
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password
# DEFAULT_FROM_EMAIL=your@gmail.com
# APP_BASE_URL=https://eod-system.up.railway.app
